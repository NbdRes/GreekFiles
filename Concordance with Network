# ============================================================
#  CORPUS FUNCTIONS
# ============================================================

read_corpus_streaming <- function(folder_path, update_progress = NULL) {
  files <- list.files(folder_path, pattern = "\\.txt$", full.names = TRUE)
  if (length(files) == 0) return(NULL)
  corpus_words <- character(0)
  corpus_files <- character(0)
  corpus_positions <- integer(0)
  for (i in seq_along(files)) {
    filename <- basename(files[i])
    if (!is.null(update_progress))
      update_progress(value = i / length(files),
                      detail = sprintf("[%d/%d] %s", i, length(files), filename))
    tryCatch({
      text  <- paste(readLines(files[i], encoding = "UTF-8", warn = FALSE), collapse = " ")
      words <- unlist(strsplit(text, "\\W+"))
      words <- words[words != ""]
      if (length(words) > 0) {
        corpus_words     <- c(corpus_words, words)
        corpus_files     <- c(corpus_files, rep(filename, length(words)))
        corpus_positions <- c(corpus_positions, seq_along(words))
      }
    }, error = function(e) NULL)
  }
  list(words = corpus_words, files = corpus_files, positions = corpus_positions)
}

build_fast_index <- function(corpus_data, update_progress = NULL) {
  words <- corpus_data$words
  if (!is.null(update_progress)) update_progress(value = 0.3, detail = "מנרמל מילים")
  normalized <- normalize_greek(words)
  if (!is.null(update_progress)) update_progress(value = 0.5, detail = "יוצר אינדקס")
  word_positions <- split(seq_along(normalized), normalized)
  if (!is.null(update_progress)) update_progress(value = 0.8, detail = "בונה שורשים")
  unique_words  <- names(word_positions)
  stems         <- sapply(unique_words, get_greek_stem, USE.NAMES = FALSE)
  stem_to_words <- split(unique_words, stems)
  if (!is.null(update_progress)) update_progress(value = 1, detail = "סיים!")
  list(corpus_words  = words,
       corpus_files  = corpus_data$files,
       corpus_positions = corpus_data$positions,
       normalized    = normalized,
       word_positions = word_positions,
       stem_to_words  = stem_to_words,
       total_words    = length(words),
       unique_words   = length(word_positions))
}

