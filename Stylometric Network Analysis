# Function to create color gradient: Light Purple -> Dark Blue
get_node_color <- function(degree, min_degree, max_degree) {
  if (max_degree == min_degree) {
    return("#8B7AB8")
  }
  
  normalized <- (degree - min_degree) / (max_degree - min_degree)
  
  light_rgb <- col2rgb("#D4C5E8")
  dark_rgb <- col2rgb("#1E3A8A")
  
  r <- round(light_rgb[1] + (dark_rgb[1] - light_rgb[1]) * normalized)
  g <- round(light_rgb[2] + (dark_rgb[2] - light_rgb[2]) * normalized)
  b <- round(light_rgb[3] + (dark_rgb[3] - light_rgb[3]) * normalized)
  
  return(rgb(r, g, b, maxColorValue = 255))
}

