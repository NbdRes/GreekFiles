remove_accents <- function(text) {
  stri_trans_general(text, "NFD; [:Nonspacing Mark:] Remove; NFC")
}

normalize_greek <- function(word) {
  tolower(remove_accents(word))
}

get_greek_stem <- function(word) {
  normalized <- normalize_greek(word)
  endings <- c("ομαι","εσθαι","ομεν","ουσι","ουσιν","ομεθα","εσθε","ονται",
               "ειν","ατο","αντο","ματος","ματων","ματι","ματα",
               "ων","οις","ους","αις","ας","ης","ην",
               "ος","ου","ον","οι","αι","α","η","ε")
  for (ending in endings) {
    if (grepl(paste0(ending,"$"), normalized) && nchar(normalized) > nchar(ending)+2)
      return(sub(paste0(ending,"$"), "", normalized))
  }
  normalized
}

