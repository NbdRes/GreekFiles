# ============================================================
#  SEARCH FUNCTION
# ============================================================

search_and_build_contexts <- function(index_obj, query_type, query, window = 10) {
  nq        <- normalize_greek(query)
  positions <- NULL
  matched_words <- NULL

  if (query_type == "exact") {
    positions     <- index_obj$word_positions[[nq]]
    matched_words <- nq
  } else if (query_type == "stem") {
    stem          <- get_greek_stem(query)
    words_in_stem <- index_obj$stem_to_words[[stem]]
    if (!is.null(words_in_stem)) {
      positions     <- unlist(index_obj$word_positions[words_in_stem])
      matched_words <- words_in_stem
    }
  } else if (query_type == "substring") {
    all_words <- names(index_obj$word_positions)
    mw        <- all_words[grepl(nq, all_words, fixed = TRUE)]
    if (length(mw) > 0) { positions <- unlist(index_obj$word_positions[mw]); matched_words <- mw }
  } else if (query_type == "pattern") {
    all_words <- names(index_obj$word_positions)
    mw        <- grep(nq, all_words, value = TRUE)
    if (length(mw) > 0) { positions <- unlist(index_obj$word_positions[mw]); matched_words <- mw }
  }

  if (is.null(positions) || length(positions) == 0)
    return(list(results = NULL, matched_words = matched_words))

  n_total  <- length(index_obj$corpus_words)
  contexts <- sapply(positions, function(pos) {
    paste(index_obj$corpus_words[max(1, pos - window):min(n_total, pos + window)], collapse = " ")
  })

  results <- data.frame(
    position = positions,
    file     = index_obj$corpus_files[positions],
    word     = index_obj$corpus_words[positions],
    context  = contexts,
    stringsAsFactors = FALSE
  )
  list(results = results, matched_words = matched_words)
}

# ============================================================
#  CONTEXT NETWORK FUNCTIONS
# ============================================================

build_context_vectors <- function(index_obj, positions, window = 10) {
  n_total      <- length(index_obj$corpus_words)
  files        <- index_obj$corpus_files[positions]
  unique_files <- unique(files)
  ctx_list     <- lapply(unique_files, function(fname) {
    pos_in_file <- positions[files == fname]
    unlist(lapply(pos_in_file, function(pos) {
      idx <- setdiff(max(1, pos - window):min(n_total, pos + window), pos)
      normalize_greek(index_obj$corpus_words[idx])
    }))
  })
  names(ctx_list) <- unique_files
  ctx_list
}

compute_context_similarity <- function(ctx_list, stopwords = greek_stopwords,
                                        min_char = 2) {
  all_words <- unique(unlist(ctx_list))
  all_words <- all_words[!all_words %in% stopwords & nchar(all_words) >= min_char]
  if (length(all_words) == 0 || length(ctx_list) < 2) return(NULL)

  file_names <- names(ctx_list)
  mat <- matrix(0, nrow = length(file_names), ncol = length(all_words),
                dimnames = list(file_names, all_words))
  for (fname in file_names) {
    tbl    <- table(ctx_list[[fname]])
    common <- intersect(names(tbl), all_words)
    mat[fname, common] <- as.numeric(tbl[common])
  }

  # TF normalisation
  rs      <- rowSums(mat)
  mat_n   <- mat / ifelse(rs == 0, 1, rs)

  cos_sim <- function(a, b) {
    d <- sqrt(sum(a^2)) * sqrt(sum(b^2))
    if (d == 0) return(0)
    sum(a * b) / d
  }

  n       <- nrow(mat_n)
  sim_mat <- matrix(0, n, n, dimnames = list(file_names, file_names))
  for (i in seq_len(n - 1))
    for (j in (i + 1):n) {
      s <- cos_sim(mat_n[i, ], mat_n[j, ])
      sim_mat[i, j] <- s
      sim_mat[j, i] <- s
    }
  sim_mat
}

# ============================================================
