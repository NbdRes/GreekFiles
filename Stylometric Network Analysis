# Server
server <- function(input, output, session) {
  
  output$file_list <- renderUI({
    req(input$files)
    div(id = "file_list",
      tags$strong(paste("Selected", length(input$files$name), "files")))
  })
  
  network_data <- eventReactive(input$create_network, {
    req(input$files)
    
    withProgress(message = 'Analyzing...', value = 0, {
      
      start_time <- Sys.time()
      n_files <- nrow(input$files)
      
      temp_dir <- tempdir()
      corpus_dir <- file.path(temp_dir, "corpus")
      dir.create(corpus_dir, showWarnings = FALSE, recursive = TRUE)
      
      incProgress(0.2, detail = "Loading corpus...")
      
      doc_names <- gsub("\\.txt$", "", input$files$name)
      
      for (i in 1:n_files) {
        clean_name <- make.names(doc_names[i])
        file.copy(input$files$datapath[i], 
                 file.path(corpus_dir, paste0(clean_name, ".txt")),
                 overwrite = TRUE)
      }
      
      parsed_corpus <- tryCatch({
        load.corpus.and.parse(
          files = "all",
          corpus.dir = corpus_dir,
          markup.type = "plain",
          corpus.lang = "Other",
          splitting.rule = "[^α-ωά-ώἀ-ὼa-zA-Z]+",
          preserve.case = FALSE
        )
      }, error = function(e) NULL)
      
      if (is.null(parsed_corpus)) {
        return(list(error = "Failed to parse corpus."))
      }
      
      incProgress(0.5, detail = "Computing frequencies...")
      
      full_freq_list <- make.frequency.list(parsed_corpus, head = 1000)
      full_freq_list <- full_freq_list[!full_freq_list %in% greek_stopwords]
      
      word_freqs <- make.table.of.frequencies(parsed_corpus, features = head(full_freq_list, 500), relative = FALSE)
      total_word_counts <- colSums(word_freqs)
      top_100_words <- head(sort(total_word_counts, decreasing = TRUE), 100)
      
      freq_list <- head(full_freq_list, input$mfw)
      
      if (length(freq_list) < 10) {
        return(list(error = "Too few words after filtering."))
      }
      
      freq_table <- make.table.of.frequencies(parsed_corpus, features = freq_list, relative = TRUE)
      
      incProgress(0.8, detail = "Computing distances...")
      
      distance_matrix <- tryCatch({
        if (input$distance_method == "delta") {
          as.matrix(dist.delta(freq_table))
        } else if (input$distance_method == "wurzburg") {
          as.matrix(dist.wurzburg(freq_table))
        } else if (input$distance_method == "eder") {
          as.matrix(dist.eder(freq_table))
        } else {
          as.matrix(dist.manhattan(freq_table))
        }
      }, error = function(e) NULL)
      
      if (is.null(distance_matrix)) {
        return(list(error = "Failed to compute distances."))
      }
      
      max_dist <- max(distance_matrix[distance_matrix != Inf])
      similarity_matrix <- 1 - (distance_matrix / max_dist)
      similarity_matrix[is.nan(similarity_matrix)] <- 0
      similarity_matrix[is.infinite(similarity_matrix)] <- 0
      diag(similarity_matrix) <- 0
      similarity_matrix[similarity_matrix < input$similarity_threshold] <- 0
      
      edges <- which(similarity_matrix > 0 & upper.tri(similarity_matrix), arr.ind = TRUE)
      
      if (nrow(edges) == 0) {
        return(list(error = "No connections above threshold."))
      }
      
      # Build nodes with gradient coloring
      node_names <- rownames(similarity_matrix)
      degrees <- rowSums(similarity_matrix > 0)
      
      min_degree <- min(degrees)
      max_degree <- max(degrees)
      
      nodes_df <- data.frame(
        id = node_names,
        label = node_names,
        title = paste0("<b>", node_names, "</b><br>", degrees, " connections"),
        value = degrees,
        stringsAsFactors = FALSE
      )
      
      nodes_df$color <- sapply(degrees, get_node_color, min_degree, max_degree)
      
      # Build edges
      edges_df <- data.frame(
        from = node_names[edges[, 1]],
        to = node_names[edges[, 2]],
        value = similarity_matrix[edges],
        title = paste0("Similarity: ", round(similarity_matrix[edges], 3)),
        color = sapply(similarity_matrix[edges], function(v) {
          if (v >= 0.7) "#7B68B0"
          else if (v >= 0.5) "#9B8BC4"
          else "#C4B8E2"
        }),
        stringsAsFactors = FALSE
      )
      
      unlink(corpus_dir, recursive = TRUE)
      
      end_time <- Sys.time()
      processing_time <- round(as.numeric(difftime(end_time, start_time, units = "secs")), 2)
      
      list(
        nodes = nodes_df,
        edges = edges_df,
        total_docs = n_files,
        features_used = length(freq_list),
        processing_time = processing_time,
        top_words = top_100_words,
        min_degree = min_degree,
        max_degree = max_degree,
        error = NULL
      )
    })
  })
  
  output$stats <- renderText({
    data <- network_data()
    
    if (!is.null(data$error)) {
      return(paste("ERROR:", data$error))
    }
    
    paste0(
      "Documents: ", data$total_docs, " | ",
      "Features: ", data$features_used, " | ",
      "Nodes: ", nrow(data$nodes), " | ",
      "Edges: ", nrow(data$edges), " | ",
      "Time: ", data$processing_time, "s"
    )
  })
  
  output$color_legend <- renderUI({
    data <- network_data()
    
    if (!is.null(data$error)) {
      return(NULL)
    }
    
    min_d <- data$min_degree
    max_d <- data$max_degree
    
    legend_degrees <- seq(min_d, max_d, length.out = 5)
    legend_colors <- sapply(legend_degrees, get_node_color, min_d, max_d)
    
    legend_items <- lapply(1:5, function(i) {
      div(class = "legend-item",
        span(class = "legend-color", style = paste0("background-color: ", legend_colors[i])),
        span(paste0(round(legend_degrees[i]), " connections"))
      )
    })
    
    tagList(
      tags$strong("Color Legend (Purple → Blue): "),
      legend_items
    )
  })
  
  output$network_plot <- renderVisNetwork({
    data <- network_data()
    
    if (!is.null(data$error)) {
      return(NULL)
    }
    
    visNetwork(data$nodes, data$edges, height = "800px", width = "100%") %>%
      visNodes(
        shape = "dot",
        borderWidth = 2,
        color = list(border = "#000000", highlight = list(border = "#000000")),
        font = list(
          size = 18, 
          face = "arial", 
          color = "#1C1C1C", 
          bold = TRUE,
          strokeWidth = 4,        # Width of the white outline
          strokeColor = "#FFFFFF"  # White halo/outline
        )
      ) %>%
      visEdges(
        smooth = list(enabled = TRUE, type = "continuous", roundness = 0.5),
        width = 2,
        selectionWidth = 4
      ) %>%
      visPhysics(
        enabled = TRUE,
        solver = "barnesHut",
        barnesHut = list(
          gravitationalConstant = -15000,
          centralGravity = 0.1,
          springLength = 350,
          springConstant = 0.005,
          damping = 0.5,
          avoidOverlap = 0.8
        ),
        stabilization = list(
          enabled = TRUE,
          iterations = 2000,
          updateInterval = 50,
          fit = TRUE
        )
      ) %>%
      visInteraction(
        navigationButtons = TRUE,
        hover = TRUE,
        tooltipDelay = 100,
        hideEdgesOnDrag = FALSE,
        zoomView = TRUE,
        dragView = TRUE,
        dragNodes = TRUE
      ) %>%
      visOptions(
        highlightNearest = list(enabled = TRUE, hover = TRUE, degree = 1),
        nodesIdSelection = TRUE
      ) %>%
      visLayout(randomSeed = 42)
  })
  
  output$word_freq_list <- renderUI({
    data <- network_data()
    
    if (!is.null(data$error) || is.null(data$top_words)) {
      return(p("Create network first", style = "color: #999; text-align: center; font-size: 16px;"))
    }
    
    word_items <- lapply(1:length(data$top_words), function(i) {
      div(class = "word-item",
        span(class = "word-rank", paste0(i, ".")),
        span(class = "word-text", names(data$top_words)[i]),
        span(class = "word-freq", paste0(" (", data$top_words[i], ")"))
      )
    })
    
    tagList(word_items)
  })
  
  output$download_html <- downloadHandler(
    filename = function() {
      paste0("stylometric_network_", format(Sys.time(), "%Y%m%d_%H%M%S"), ".html")
    },
    content = function(file) {
      data <- network_data()
      
      vn <- visNetwork(data$nodes, data$edges) %>%
        visNodes(
          shape = "dot", 
          borderWidth = 2, 
          color = list(border = "#000000"),
          font = list(
            size = 18, 
            face = "arial", 
            color = "#1C1C1C", 
            bold = TRUE,
            strokeWidth = 4,
            strokeColor = "#FFFFFF"
          )
        ) %>%
        visEdges(smooth = list(enabled = TRUE, type = "continuous", roundness = 0.5)) %>%
        visPhysics(
          enabled = TRUE,
          solver = "barnesHut",
          barnesHut = list(
            gravitationalConstant = -15000,
            centralGravity = 0.1,
            springLength = 350,
            springConstant = 0.005,
            damping = 0.5
          ),
          stabilization = list(iterations = 2000)
        ) %>%
        visInteraction(navigationButtons = TRUE, dragNodes = TRUE) %>%
        visOptions(highlightNearest = TRUE)
      
      visSave(vn, file)
    }
  )
}

shinyApp(ui = ui, server = server)
