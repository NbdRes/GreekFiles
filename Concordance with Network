server <- function(input, output, session) {

  rv <- reactiveValues(
    folder_path    = NULL,
    index_obj      = NULL,
    search_results = NULL,
    matched_words  = NULL
  )

  # ── Folder chooser ─────────────────────────────────────────
  volumes <- c(Home = fs::path_home(), getVolumes()())
  shinyDirChoose(input, "folder", roots = volumes, session = session)

  observeEvent(input$folder, {
    if (!is.integer(input$folder)) {
      rv$folder_path <- parseDirPath(roots = volumes, input$folder)
      if (length(rv$folder_path) > 0) {
        index_file <- file.path(rv$folder_path, ".concordance_index.rds")
        if (file.exists(index_file)) {
          showModal(modalDialog(
            title = "🔔 נמצא אינדקס שמור",
            HTML("<p>נמצא אינדקס קיים בתיקייה.</p>
                  <p><b>טען קיים</b> — מהיר (שניות)</p>
                  <p><b>בנה מחדש</b> — איטי יותר</p>"),
            footer = tagList(
              actionButton("load_existing", "📥 טען קיים (מומלץ)", class = "btn-success"),
              actionButton("build_new",     "🔨 בנה מחדש",         class = "btn-warning"),
              modalButton("❌ ביטול")),
            size = "s"))
        } else {
          build_index_from_folder(rv$folder_path)
        }
      }
    }
  })

  observeEvent(input$load_existing, {
    removeModal()
    index_file <- file.path(rv$folder_path, ".concordance_index.rds")
    withProgress(message = "טוען אינדקס...", value = 0.5, {
      rv$index_obj <- load_index(index_file)
    })
    showNotification(
      sprintf("✅ אינדקס נטען — %s מילים, %s ייחודיות",
              format(rv$index_obj$total_words,  big.mark = ","),
              format(rv$index_obj$unique_words, big.mark = ",")),
      type = "message", duration = 8)
  })

  observeEvent(input$build_new, {
    removeModal()
    build_index_from_folder(rv$folder_path)
  })

  build_index_from_folder <- function(folder_path) {
    progress <- Progress$new(session, min = 0, max = 1)
    on.exit(progress$close())
    tryCatch({
      progress$set(message = "קורא קבצים...", value = 0)
      corpus_data <- read_corpus_streaming(folder_path,
        update_progress = function(value, detail)
          progress$set(message = "קורא קבצים...", value = value * 0.70, detail = detail))
      if (is.null(corpus_data)) {
        showNotification("❌ לא נמצאו קבצי TXT", type = "error"); return()
      }
      progress$set(message = "בונה אינדקס...", value = 0.70)
      rv$index_obj <- build_fast_index(corpus_data,
        update_progress = function(value, detail)
          progress$set(message = "בונה אינדקס...", value = 0.70 + value * 0.25, detail = detail))
      progress$set(message = "שומר...", value = 0.96)
      save_index(rv$index_obj, file.path(folder_path, ".concordance_index.rds"))
      progress$set(message = "הושלם!", value = 1)
      showNotification(
        sprintf("✅ אינדקס מוכן — %s מילים, %s ייחודיות",
                format(rv$index_obj$total_words,  big.mark = ","),
                format(rv$index_obj$unique_words, big.mark = ",")),
        type = "message", duration = 10)
    }, error = function(e)
      showNotification(paste("❌ שגיאה:", e$message), type = "error", duration = 10))
  }

  # ── Save / Load index manually ─────────────────────────────
  observeEvent(input$save_index_btn, {
    req(rv$index_obj, rv$folder_path)
    save_index(rv$index_obj, file.path(rv$folder_path, ".concordance_index.rds"))
    showNotification("💾 אינדקס נשמר!", type = "message", duration = 4)
  })

  observeEvent(input$load_index_file, {
    req(input$load_index_file)
    withProgress(message = "טוען...", value = 0.5, {
      rv$index_obj <- load_index(input$load_index_file$datapath)
    })
    showNotification(
      sprintf("✅ אינדקס נטען — %s מילים",
              format(rv$index_obj$total_words, big.mark = ",")),
      type = "message", duration = 5)
  })

  # ── Corpus info ────────────────────────────────────────────
  output$folder_selected <- renderText({
    if (!is.null(rv$folder_path)) paste("✅", basename(rv$folder_path))
    else "❌ לא נבחרה תיקייה"
  })

  output$corpus_info <- renderText({
    if (is.null(rv$index_obj)) "⏳ טרם נטען אינדקס"
    else sprintf("✅ מוכן\n📝 %s מילים\n🔤 %s ייחודיות",
                 format(rv$index_obj$total_words,  big.mark = ","),
                 format(rv$index_obj$unique_words, big.mark = ","))
  })

  # ── Search ─────────────────────────────────────────────────
  observeEvent(input$search_btn, {
    req(rv$index_obj, input$query)
    withProgress(message = "מחפש...", value = 0.5, {
      result <- search_and_build_contexts(
        rv$index_obj, input$search_type, input$query,
        window = input$ctx_window)
      rv$search_results <- result$results
      rv$matched_words  <- result$matched_words
    })
    if (is.null(rv$search_results) || nrow(rv$search_results) == 0)
      showNotification("❌ לא נמצאו תוצאות", type = "warning", duration = 5)
    else
      showNotification(
        sprintf("✅ נמצאו %s תוצאות", format(nrow(rv$search_results), big.mark = ",")),
        type = "message", duration = 5)
  })

  # ── Concordance tab outputs ────────────────────────────────
  output$results_title <- renderText({
    if (!is.null(rv$search_results) && nrow(rv$search_results) > 0)
      sprintf("נמצאו %s תוצאות עבור «%s» (חלון ±%d)",
              format(nrow(rv$search_results), big.mark = ","),
              input$query, input$ctx_window)
    else if (!is.null(rv$search_results)) "לא נמצאו תוצאות"
    else "הזן מילה ולחץ חפש"
  })

  output$matched_words <- renderText({
    req(rv$matched_words)
    mw <- rv$matched_words
    if (length(mw) > 50)
      paste("נמצאו", length(mw), "צורות (50 ראשונות):\n",
            paste(head(sort(mw), 50), collapse = ", "), "\n...")
    else
      paste("נמצאו", length(mw), "צורות:\n", paste(sort(mw), collapse = ", "))
  })

  output$results_display <- renderUI({
    req(rv$search_results)
    if (nrow(rv$search_results) == 0)
      return(p("אין תוצאות.", style = "color:#999;"))
    max_display   <- 200
    results_subset <- head(rv$search_results, max_display)
    items <- lapply(seq_len(nrow(results_subset)), function(i) {
      r <- results_subset[i, ]
      div(class = "result-item",
        tags$b(sprintf("%d.  [%s]  מיקום: %s", i, r$file,
                       format(r$position, big.mark = ","))),
        div(style = "margin-top:4px; color:#333;", r$context))
    })
    result_ui <- do.call(tagList, items)
    if (nrow(rv$search_results) > max_display)
      result_ui <- tagList(result_ui,
        div(style = "text-align:center; padding:16px; color:#999;",
            sprintf("מוצגים %d מתוך %s תוצאות",
                    max_display, format(nrow(rv$search_results), big.mark = ","))))
    result_ui
  })

  # ── Context network ────────────────────────────────────────
  ctx_network_data <- eventReactive(input$build_ctx_network, {
    req(rv$index_obj, rv$search_results)

    withProgress(message = "בונה רשת הקשרית...", value = 0, {
      incProgress(0.25, detail = "בונה וקטורי הקשר")
      ctx_vectors <- build_context_vectors(
        rv$index_obj,
        rv$search_results$position,
        window = input$ctx_window)

      if (length(ctx_vectors) < 2)
        return(list(error = "נדרשים לפחות 2 קבצים שמכילים את המילה"))

      incProgress(0.50, detail = "מחשב דמיון קוסינוס")
      sw  <- if (input$ctx_remove_stopwords) greek_stopwords else character(0)
      sim_mat <- compute_context_similarity(ctx_vectors, stopwords = sw,
                                             min_char = input$ctx_min_char)
      if (is.null(sim_mat))
        return(list(error = "לא ניתן לחשב — vocabulary ריק לאחר סינון"))

      sim_mat[sim_mat < input$ctx_threshold] <- 0
      diag(sim_mat) <- 0

      edges_idx <- which(sim_mat > 0 & upper.tri(sim_mat), arr.ind = TRUE)
      if (nrow(edges_idx) == 0)
        return(list(error = sprintf(
          "אין קשרים מעל סף %.2f — נסה להוריד את הסף", input$ctx_threshold)))

      node_names  <- rownames(sim_mat)
      degrees     <- rowSums(sim_mat > 0)
      min_d       <- min(degrees); max_d <- max(degrees)
      occ_counts  <- table(rv$search_results$file)

      nodes_df <- data.frame(
        id    = node_names,
        label = gsub("\\.txt$", "", node_names),
        title = mapply(function(nm, deg) {
          occ <- as.integer(occ_counts[nm])
          if (is.na(occ)) occ <- 0L
          paste0("<b>", gsub("\\.txt$", "", nm), "</b><br>",
                 "מופעים: ", occ, "<br>קשרים: ", deg)
        }, node_names, degrees, SIMPLIFY = TRUE),
        value = pmax(1L, as.integer(occ_counts[node_names])),
        color = sapply(degrees, get_node_color, min_d, max_d),
        stringsAsFactors = FALSE
      )

      edges_df <- data.frame(
        from  = node_names[edges_idx[, 1]],
        to    = node_names[edges_idx[, 2]],
        value = sim_mat[edges_idx],
        title = paste0("דמיון: ", round(sim_mat[edges_idx], 3)),
        color = sapply(sim_mat[edges_idx], edge_color),
        stringsAsFactors = FALSE
      )

      incProgress(1, detail = "הושלם!")
      list(nodes = nodes_df, edges = edges_df,
           n_files = length(ctx_vectors),
           n_edges = nrow(edges_df),
           min_d = min_d, max_d = max_d,
           query = input$query, error = NULL)
    })
  })

  output$ctx_network_stats <- renderText({
    d <- ctx_network_data()
    if (!is.null(d$error)) return(paste("⚠️", d$error))
    paste0("מילה: «", d$query, "»  |  ",
           "קבצים ברשת: ", d$n_files, "  |  ",
           "קשרים: ", d$n_edges, "  |  ",
           "חלון: ±", input$ctx_window, "  |  ",
           "סף: ", input$ctx_threshold)
  })

  output$ctx_color_legend <- renderUI({
    d <- ctx_network_data()
    if (!is.null(d$error) || is.null(d$min_d)) return(NULL)
    lg_deg  <- seq(d$min_d, d$max_d, length.out = 5)
    lg_col  <- sapply(lg_deg, get_node_color, d$min_d, d$max_d)
    items   <- lapply(seq_len(5), function(i)
      div(class = "legend-item",
        span(class = "legend-color",
             style = paste0("background-color:", lg_col[i], ";")),
        span(paste0(round(lg_deg[i]), " קשרים"))))
    tagList(tags$strong("צבע צומת (סגול → כחול): "), items)
  })

  make_vis <- function(nodes, edges) {
    visNetwork(nodes, edges, width = "100%") %>%
      visNodes(
        shape = "dot", borderWidth = 2,
        color = list(border = "#333333",
                     highlight = list(border = "#000000")),
        font  = list(size = 16, face = "arial", color = "#1C1C1C",
                     bold = TRUE, strokeWidth = 3, strokeColor = "#FFFFFF")) %>%
      visEdges(
        smooth = list(enabled = TRUE, type = "continuous", roundness = 0.4),
        width = 2, selectionWidth = 4) %>%
      visPhysics(
        solver = "barnesHut",
        barnesHut = list(gravitationalConstant = -12000,
                         centralGravity = 0.15,
                         springLength = 300,
                         springConstant = 0.008,
                         damping = 0.5,
                         avoidOverlap = 0.9),
        stabilization = list(enabled = TRUE, iterations = 1500,
                             updateInterval = 50, fit = TRUE)) %>%
      visInteraction(navigationButtons = TRUE, hover = TRUE,
                     zoomView = TRUE, dragNodes = TRUE,
                     tooltipDelay = 80) %>%
      visOptions(highlightNearest = list(enabled = TRUE, hover = TRUE, degree = 1),
                 nodesIdSelection = TRUE) %>%
      visLayout(randomSeed = 42)
  }

  output$ctx_network_plot <- renderVisNetwork({
    d <- ctx_network_data()
    if (!is.null(d$error)) return(NULL)
    make_vis(d$nodes, d$edges) %>% visNetworkProxy("ctx_network_plot")
    make_vis(d$nodes, d$edges)
  })

  output$download_ctx_html <- downloadHandler(
    filename = function() {
      safe_q <- gsub("[^a-zA-Zα-ωά-ώ]", "", input$query)
      paste0("context_network_", safe_q, "_",
             format(Sys.time(), "%Y%m%d_%H%M%S"), ".html")
    },
    content = function(file) {
      d  <- ctx_network_data()
      vn <- make_vis(d$nodes, d$edges)
      visSave(vn, file)
    }
  )
}

